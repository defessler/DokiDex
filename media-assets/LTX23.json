{
  "workflow": {
    "nodes": [],
    "links": [],
    "version": 0.4
  },
  "prompt": {
    "ckpt": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "ltx-2.3-22b-dev-nvfp4.safetensors"
      }
    },
    "avae": {
      "class_type": "LTXVAudioVAELoader",
      "inputs": {
        "ckpt_name": "ltx-2.3-22b-dev-nvfp4.safetensors"
      }
    },
    "te": {
      "class_type": "LTXAVTextEncoderLoader",
      "inputs": {
        "text_encoder": "gemma_3_12B_it_fp8_scaled.safetensors",
        "ckpt_name": "ltx-2.3-22b-dev-nvfp4.safetensors",
        "device": "default"
      }
    },
    "pos": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "${prompt}",
        "clip": [
          "te",
          0
        ]
      }
    },
    "neg": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "pc game, console game, video game, cartoon, childish, ugly, blurry, distorted",
        "clip": [
          "te",
          0
        ]
      }
    },
    "cond": {
      "class_type": "LTXVConditioning",
      "inputs": {
        "positive": [
          "pos",
          0
        ],
        "negative": [
          "neg",
          0
        ],
        "frame_rate": 24.0
      }
    },
    "vlat": {
      "class_type": "EmptyLTXVLatentVideo",
      "inputs": {
        "width": 768,
        "height": 512,
        "length": 97,
        "batch_size": 1
      }
    },
    "alat": {
      "class_type": "LTXVEmptyLatentAudio",
      "inputs": {
        "frames_number": 97,
        "frame_rate": 24,
        "batch_size": 1,
        "audio_vae": [
          "avae",
          0
        ]
      }
    },
    "avcat": {
      "class_type": "LTXVConcatAVLatent",
      "inputs": {
        "video_latent": [
          "vlat",
          0
        ],
        "audio_latent": [
          "alat",
          0
        ]
      }
    },
    "sigmas": {
      "class_type": "LTXVScheduler",
      "inputs": {
        "steps": 20,
        "max_shift": 2.05,
        "base_shift": 0.95,
        "stretch": true,
        "terminal": 0.1,
        "latent": [
          "avcat",
          0
        ]
      }
    },
    "samp": {
      "class_type": "KSamplerSelect",
      "inputs": {
        "sampler_name": "euler"
      }
    },
    "noise": {
      "class_type": "RandomNoise",
      "inputs": {
        "noise_seed": "%%_COMFYFIXME_${seed}_ENDFIXME_%%"
      }
    },
    "gp_aud": {
      "class_type": "GuiderParameters",
      "inputs": {
        "modality": "AUDIO",
        "cfg": 7.0,
        "stg": 1.0,
        "perturb_attn": true,
        "rescale": 0.7,
        "modality_scale": 3.0,
        "skip_step": 0,
        "cross_attn": true
      }
    },
    "gp_vid": {
      "class_type": "GuiderParameters",
      "inputs": {
        "modality": "VIDEO",
        "cfg": 3.0,
        "stg": 1.0,
        "perturb_attn": true,
        "rescale": 0.9,
        "modality_scale": 3.0,
        "skip_step": 0,
        "cross_attn": true,
        "parameters": [
          "gp_aud",
          0
        ]
      }
    },
    "guider": {
      "class_type": "MultimodalGuider",
      "inputs": {
        "model": [
          "ckpt",
          0
        ],
        "positive": [
          "cond",
          0
        ],
        "negative": [
          "cond",
          1
        ],
        "parameters": [
          "gp_vid",
          0
        ],
        "skip_blocks": ""
      }
    },
    "sca": {
      "class_type": "SamplerCustomAdvanced",
      "inputs": {
        "noise": [
          "noise",
          0
        ],
        "guider": [
          "guider",
          0
        ],
        "sampler": [
          "samp",
          0
        ],
        "sigmas": [
          "sigmas",
          0
        ],
        "latent_image": [
          "avcat",
          0
        ]
      }
    },
    "split": {
      "class_type": "LTXVSeparateAVLatent",
      "inputs": {
        "av_latent": [
          "sca",
          0
        ]
      }
    },
    "vdec": {
      "class_type": "LTXVTiledVAEDecode",
      "inputs": {
        "vae": [
          "ckpt",
          2
        ],
        "latents": [
          "split",
          0
        ],
        "horizontal_tiles": 2,
        "vertical_tiles": 2,
        "overlap": 6,
        "last_frame_fix": false,
        "working_device": "auto",
        "working_dtype": "auto"
      }
    },
    "adec": {
      "class_type": "LTXVAudioVAEDecode",
      "inputs": {
        "samples": [
          "split",
          1
        ],
        "audio_vae": [
          "avae",
          0
        ]
      }
    },
    "mkvid": {
      "class_type": "CreateVideo",
      "inputs": {
        "images": [
          "vdec",
          0
        ],
        "audio": [
          "adec",
          0
        ],
        "fps": 24.0
      }
    },
    "save": {
      "class_type": "SaveVideo",
      "inputs": {
        "video": [
          "mkvid",
          0
        ],
        "filename_prefix": "LTX23/ltx_t2v_av",
        "format": "mp4",
        "codec": "h264"
      }
    }
  }
}
