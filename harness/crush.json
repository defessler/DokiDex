{
  "$schema": "https://charm.land/crush.json",
  "providers": {
    "local": {
      "name": "DokiCode local (llama-swap)",
      "type": "openai-compat",
      "base_url": "http://127.0.0.1:8080/v1/",
      "api_key": "dummy",
      "models": [
        {
          "id": "coder-fast",
          "name": "Qwen3-Coder-30B-A3B (GPU, fast)",
          "context_window": 131072,
          "default_max_tokens": 8192
        },
        {
          "id": "coder-big",
          "name": "gpt-oss-120b (MoE offload, quality)",
          "context_window": 131072,
          "default_max_tokens": 8192
        },
        {
          "id": "coder-fast-lite",
          "name": "Qwen3-Coder-30B-A3B @64k (coexists with FIM autocomplete)",
          "context_window": 65536,
          "default_max_tokens": 8192
        },
        {
          "id": "fast-candidate-gptoss20b",
          "name": "gpt-oss-20b (GPU, fast; CoT in reasoning_content)",
          "context_window": 131072,
          "default_max_tokens": 8192
        }
      ]
    }
  },
  "models": {
    "large": { "model": "coder-fast-lite", "provider": "local" },
    "small": { "model": "coder-fast-lite", "provider": "local" }
  },
  "mcp": {
    "websearch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["duckduckgo-mcp-server"],
      "timeout": 120
    },
    "memory": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--with", "mcp[cli]", "D:/Projects/DokiDex/serving/memory-mcp/server.py"],
      "timeout": 120
    }
  }
}
