<UserControl x:Class="DokiDex.Control.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DokiDex.Control.ViewModels">
  <UserControl.Resources>

    <!-- ============ service card ============ -->
    <DataTemplate x:Key="ServiceCard" DataType="{x:Type vm:ServiceViewModel}">
      <Border Background="{StaticResource Surface2Brush}" BorderBrush="#1A243140"
              BorderThickness="1" CornerRadius="8" Margin="0,0,14,14" Width="336">
        <Border.Style>
          <Style TargetType="Border">
            <Style.Triggers>
              <DataTrigger Binding="{Binding StateKind}" Value="notinstalled">
                <Setter Property="Opacity" Value="0.5"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding StateKind}" Value="crashed">
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrightBrush}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" CornerRadius="8,0,0,8" Background="{Binding Group, Converter={StaticResource GroupAccent}}"/>
          <StackPanel Grid.Column="1" Margin="16,14,16,14">

            <!-- header: dot + name + port -->
            <DockPanel>
              <Ellipse Width="8" Height="8" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,1,9,0"
                       Fill="{Binding StateKind, Converter={StaticResource StateBrush}}">
                <Ellipse.Style>
                  <Style TargetType="Ellipse">
                    <Style.Triggers>
                      <!-- running-but-not-healthy = starting/loading: a calm pulse signals "working on it" -->
                      <DataTrigger Binding="{Binding StateKind}" Value="degraded">
                        <DataTrigger.EnterActions>
                          <BeginStoryboard Name="Pulse">
                            <Storyboard>
                              <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3"
                                               Duration="0:0:0.75" AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                          </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                          <StopStoryboard BeginStoryboardName="Pulse"/>
                        </DataTrigger.ExitActions>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Ellipse.Style>
              </Ellipse>
              <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}" Foreground="{StaticResource DimBrush}"
                         FontSize="12" VerticalAlignment="Center">
                <Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
              </TextBlock>
              <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="14"/>
            </DockPanel>

            <TextBlock Text="{Binding StateLabel}" Foreground="{Binding StateKind, Converter={StaticResource StateBrush}}"
                       FontSize="12" Margin="19,3,0,0"/>
            <TextBlock Text="{Binding Detail}" Style="{StaticResource Mono}" Foreground="{StaticResource DimBrush}"
                       FontSize="11" Margin="19,2,0,0" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding VersionLine}" Style="{StaticResource Mono}" FontSize="10.5" Margin="19,2,0,0"
                       Foreground="{Binding HasUpdate, Converter={StaticResource WarnBrush}}"
                       Visibility="{Binding HasVersion, Converter={StaticResource BoolVis}}" TextTrimming="CharacterEllipsis"/>

            <!-- model swap (llama-swap: warm-load a configured coder model) -->
            <ItemsControl ItemsSource="{Binding ConfiguredModels}" Margin="17,7,0,0"
                          Visibility="{Binding HasModelSwap, Converter={StaticResource BoolVis}}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Content="{Binding}" Style="{StaticResource IconBtn}" FontSize="10.5" ToolTip="warm-load this coder model"
                          Command="{Binding DataContext.SwapModelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- actions -->
            <WrapPanel Margin="17,9,0,0">
              <Button Content="▶ start" Style="{StaticResource IconBtn}" Command="{Binding StartCommand}"
                      Visibility="{Binding Running, Converter={StaticResource InvBoolVis}}"/>
              <Button Content="↻" Style="{StaticResource IconBtn}" Command="{Binding RestartCommand}" ToolTip="restart"
                      Visibility="{Binding Running, Converter={StaticResource BoolVis}}"/>
              <Button Content="■ stop" Style="{StaticResource IconBtn}" Command="{Binding StopCommand}"
                      Visibility="{Binding Running, Converter={StaticResource BoolVis}}"/>
              <Button Content="⎘ UI" Style="{StaticResource IconBtn}" Command="{Binding OpenUiCommand}"
                      Visibility="{Binding HasUi, Converter={StaticResource BoolVis}}"/>
              <Button Content="⚡ test" Style="{StaticResource IconBtn}" Command="{Binding TestCommand}"
                      ToolTip="Run the smallest real generation for this service."/>
            </WrapPanel>

            <!-- test result tray -->
            <Border Margin="17,9,0,0" Background="{StaticResource BgBrush}" CornerRadius="4" Padding="9,6"
                    Visibility="{Binding HasTestResult, Converter={StaticResource BoolVis}}">
              <DockPanel>
                <Button DockPanel.Dock="Right" Content="open" Style="{StaticResource IconBtn}" Margin="6,0,0,0"
                        Command="{Binding OpenTestFileCommand}"
                        Visibility="{Binding HasTestFile, Converter={StaticResource BoolVis}}"/>
                <TextBlock Text="{Binding TestResult}" Style="{StaticResource Mono}" FontSize="11" TextWrapping="Wrap"/>
              </DockPanel>
            </Border>

          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,18,14,18">
    <StackPanel>

      <!-- ===== mode switcher ===== -->
      <TextBlock Text="MODE — the GPU runs one group at a time" Style="{StaticResource SectionHeader}"/>
      <DockPanel Margin="0,2,0,6">
        <Button DockPanel.Dock="Right" Content="⏻ Stop All" Style="{StaticResource BtnDanger}"
                Command="{Binding StopAllCommand}" VerticalAlignment="Top"/>
        <WrapPanel>
          <Button Tag="agent" Style="{StaticResource ModeBtn}" Command="{Binding SwitchModeCommand}" CommandParameter="agent"
                  MouseEnter="ModeHover" MouseLeave="ModeUnhover" ToolTip="chat + code (llama-swap + tts)">
            <StackPanel><TextBlock Text="AGENT" FontWeight="SemiBold"/><TextBlock Text="chat + code" FontSize="10" Foreground="{StaticResource DimBrush}"/></StackPanel>
          </Button>
          <Button Tag="coexist" Style="{StaticResource ModeBtn}" Command="{Binding SwitchModeCommand}" CommandParameter="coexist"
                  MouseEnter="ModeHover" MouseLeave="ModeUnhover" ToolTip="chat + code + editor autocomplete (llama-swap + fim)">
            <StackPanel><TextBlock Text="COEXIST" FontWeight="SemiBold"/><TextBlock Text="+ autocomplete" FontSize="10" Foreground="{StaticResource DimBrush}"/></StackPanel>
          </Button>
          <Button Tag="media" Style="{StaticResource ModeBtn}" Command="{Binding SwitchModeCommand}" CommandParameter="media"
                  MouseEnter="ModeHover" MouseLeave="ModeUnhover" ToolTip="image + video (SwarmUI + prompt-rewriter). Stops the LLM.">
            <StackPanel><TextBlock Text="MEDIA" FontWeight="SemiBold"/><TextBlock Text="image + video" FontSize="10" Foreground="{StaticResource DimBrush}"/></StackPanel>
          </Button>
        </WrapPanel>
      </DockPanel>
      <Border Background="{StaticResource SurfaceBrush}" CornerRadius="5" Padding="11,8" Margin="0,2,0,18"
              BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <TextBlock Text="{Binding SwitchExplain}" Foreground="{StaticResource TextBrush}" FontSize="12" TextWrapping="Wrap"/>
      </Border>

      <!-- ===== DokiCode band (the coding / LLM subsystem) ===== -->
      <StackPanel Opacity="{Binding LlmActive, Converter={StaticResource BoolOpacity}, ConverterParameter=0.55}">
        <TextBlock Style="{StaticResource SectionHeader}" FontSize="10.5" Margin="2,0,0,8">
          <Run Text="DokiCode" Foreground="{StaticResource ReactorDimBrush}"/><Run Text="  ·  chat + code" Foreground="{StaticResource DimBrush}"/>
        </TextBlock>   <!-- coding sub-brand; structural etched cyan (boot ring), NOT the emitting TealBrush -->

        <ItemsControl ItemsSource="{Binding LlmServices}" ItemTemplate="{StaticResource ServiceCard}">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        </ItemsControl>
      </StackPanel>

      <!-- ===== DokiGen band (the image/video subsystem) ===== -->
      <StackPanel Margin="0,24,0,0" Opacity="{Binding MediaActive, Converter={StaticResource BoolOpacity}, ConverterParameter=0.55}">
        <TextBlock Style="{StaticResource SectionHeader}" FontSize="10.5" Margin="2,0,0,8">
          <Run Text="DokiGen" Foreground="{StaticResource AmberBrush}"/><Run Text="  ·  image + video" Foreground="{StaticResource DimBrush}"/>
        </TextBlock>   <!-- media sub-brand; etched gold -->
        <ItemsControl ItemsSource="{Binding MediaServices}" ItemTemplate="{StaticResource ServiceCard}">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>

  <!-- empty state — echoes the boot's "doki status json" pre-flight; collapses once cards arrive.
       Two variants so a HARD failure (poll returned null) isn't masked as a perpetual "loading". -->
  <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
        Visibility="{Binding TotalServiceCount, Converter={StaticResource ZeroToVis}}">

    <!-- loading: first poll pending / in flight (StatusUnavailable == false) -->
    <StackPanel IsHitTestVisible="False" Visibility="{Binding StatusUnavailable, Converter={StaticResource InvBoolVis}}">
      <Path Data="{StaticResource SigilGeo}" Stretch="Uniform" Width="40" Height="40"
            Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1" Opacity="0.4" HorizontalAlignment="Center"/>
      <TextBlock Text="reading  doki status …" Style="{StaticResource Mono}" FontSize="12"
                 Foreground="{StaticResource DimBrush}" Margin="0,16,0,0" HorizontalAlignment="Center"/>
      <Ellipse Width="5" Height="5" Margin="0,12,0,0" HorizontalAlignment="Center" Fill="{StaticResource TealBrush}">
        <Ellipse.Triggers>
          <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.6" AutoReverse="True" RepeatBehavior="Forever"/>
          </Storyboard></BeginStoryboard></EventTrigger>
        </Ellipse.Triggers>
      </Ellipse>
    </StackPanel>

    <!-- error: a poll returned nothing (stack down / pwsh not on PATH / wrong root). No pulse; offer Retry. -->
    <StackPanel Visibility="{Binding StatusUnavailable, Converter={StaticResource BoolVis}}">
      <Path Data="{StaticResource SigilGeo}" Stretch="Uniform" Width="40" Height="40"
            Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1" Opacity="0.22" HorizontalAlignment="Center"/>
      <TextBlock Text="doki status unavailable" Style="{StaticResource Mono}" FontSize="12.5"
                 Foreground="{StaticResource AmberBrush}" Margin="0,16,0,0" HorizontalAlignment="Center"/>
      <TextBlock Text="is the stack running?   (needs PowerShell 7 — pwsh — on PATH)" Style="{StaticResource Mono}"
                 FontSize="11" Foreground="{StaticResource DimBrush}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
      <Button Content="↻  Retry" Style="{StaticResource IconBtn}" Margin="0,14,0,0" HorizontalAlignment="Center"
              Command="{Binding RetryCommand}"/>
    </StackPanel>
  </Grid>
  </Grid>
</UserControl>
