<Window x:Class="DokiDex.Control.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Confirm switch" SizeToContent="Height" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="False" Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">

  <!-- Custom chrome to match the app (no grey OS caption). CaptionHeight=34 makes the brand strip
       draggable natively; the modal is fixed-size with explicit Cancel/Switch buttons + Esc (IsCancel). -->
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="0" CornerRadius="0"
                        GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
    <StackPanel>
      <!-- brand caption strip (draggable) -->
      <Border Height="34" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
          <Path Data="{StaticResource SigilGeo}" Stretch="Uniform" Width="13" Height="13"
                Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1" Opacity="0.8" VerticalAlignment="Center"/>
          <TextBlock Text="Confirm switch" Margin="9,0,0,0" VerticalAlignment="Center"
                     Foreground="{StaticResource DimBrush}" FontSize="11.5"/>
        </StackPanel>
      </Border>

      <Border Padding="20,18,20,20">
        <StackPanel>
          <TextBlock x:Name="TitleText" Style="{StaticResource H1}" Margin="0,0,0,4"/>
          <TextBlock Text="The GPU can only run one group at a time." Foreground="{StaticResource DimBrush}"
                     FontSize="12" Margin="0,0,0,16"/>

          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
              <TextBlock Text="WILL STOP" Style="{StaticResource SectionHeader}" Foreground="{StaticResource DangerBrightBrush}"/>
              <ItemsControl x:Name="StopList">
                <ItemsControl.ItemTemplate><DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" Style="{StaticResource Mono}" FontSize="12" Margin="0,2"/>
                </DataTemplate></ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
              <TextBlock Text="WILL START" Style="{StaticResource SectionHeader}" Foreground="{StaticResource TealBrush}"/>
              <ItemsControl x:Name="StartList">
                <ItemsControl.ItemTemplate><DataTemplate>
                  <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" Style="{StaticResource Mono}" FontSize="12" Margin="0,2"/>
                </DataTemplate></ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <Border Background="{StaticResource SurfaceBrush}" CornerRadius="5" Padding="11,8" Margin="0,16,0,0"
                  BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
            <TextBlock x:Name="HeadroomText" Style="{StaticResource Mono}" FontSize="12" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
          </Border>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnGhost}" Padding="18,7" IsCancel="True" Click="OnCancel"/>
            <Button x:Name="ConfirmBtn" Content="Switch" Style="{StaticResource Btn}" Background="{StaticResource AmberBrush}"
                    Foreground="#FF0A0E14" Padding="18,7" Margin="8,0,0,0" Click="OnConfirm"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</Window>
