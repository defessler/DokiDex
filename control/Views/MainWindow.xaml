<Window x:Class="DokiCode.Control.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DokiCode Control" Height="760" Width="1100"
        MinHeight="560" MinWidth="900"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="216"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ============ LEFT RAIL ============ -->
    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
      <DockPanel Margin="14,14,14,12">

        <!-- brand wordmark — the splash voice: light, hair-spaced (no FontStretch/ScaleX) -->
        <TextBlock DockPanel.Dock="Top" Text="D O K I C O D E" FontWeight="Thin" FontSize="19"
                   FontFamily="Segoe UI Variable Display, Segoe UI Light, Segoe UI" Foreground="{StaticResource TextBrush}"/>
        <TextBlock DockPanel.Dock="Top" Text="local intelligence stack" Foreground="{StaticResource DimBrush}"
                   FontSize="10.5" Margin="0,1,0,16"/>

        <!-- GPU meter -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
          <TextBlock Text="{Binding Gpu.GroupLabel}" Foreground="{StaticResource DimBrush}" FontSize="10.5" Margin="0,0,0,5" TextTrimming="CharacterEllipsis"/>
          <Border Height="18" Background="{StaticResource BgBrush}" CornerRadius="4"
                  BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="1">
            <ProgressBar Minimum="0" Maximum="{Binding Gpu.TotalMB}" Value="{Binding Gpu.UsedMB}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{Binding Gpu.ActiveGroup, Converter={StaticResource GroupAccent}}"/>
          </Border>
          <TextBlock Text="{Binding Gpu.Headline}" Style="{StaticResource Mono}" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding Gpu.SubLine}" Foreground="{Binding Gpu.LowHeadroom, Converter={StaticResource WarnBrush}}"
                     Style="{StaticResource Mono}" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- nav -->
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="VIEW" Style="{StaticResource SectionHeader}"/>
          <Button Content="▸  Dashboard" Style="{StaticResource NavBtn}" Click="NavDashboard"/>
          <Button Content="▸  Logs" Style="{StaticResource NavBtn}" Click="NavLogs"/>
        </StackPanel>

        <!-- global actions (bottom) -->
        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="GLOBAL" Style="{StaticResource SectionHeader}" Margin="2,0,0,6"/>
          <Button Content="⟳  Check Updates" Style="{StaticResource NavBtn}" Command="{Binding CheckUpdatesCommand}"
                  ToolTip="Check for newer SwarmUI (git) + llama-swap (GitHub) releases."/>
          <Button Content="✓  Verify stack" Style="{StaticResource NavBtn}" Command="{Binding VerifyCommand}"
                  ToolTip="Full-stack smoke test (opens a console)."/>
          <Button Content="⏻  Stop All" Style="{StaticResource NavBtn}" Foreground="{StaticResource DangerBrightBrush}"
                  Command="{Binding StopAllCommand}" ToolTip="Stop every service and free the GPU."/>
        </StackPanel>

        <Grid/>
      </DockPanel>
    </Border>

    <!-- ============ CONTENT ============ -->
    <ContentControl Grid.Row="0" Grid.Column="1" x:Name="PageHost"/>

    <!-- ============ STATUS STRIP ============ -->
    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0">
      <DockPanel Margin="14,7">
        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource DimBrush}" FontSize="11" VerticalAlignment="Center">
          <Run Text="updated "/><Run Text="{Binding LastUpdated}"/>
        </TextBlock>
        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource InfoBrush}" FontSize="12"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
