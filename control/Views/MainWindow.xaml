<Window x:Class="DokiDex.Control.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DokiDex Control" Height="760" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

  <!-- Custom chrome: WindowChrome keeps native resize / Aero Snap / Win+Arrow / double-click-maximize
       while replacing the grey OS caption. AllowsTransparency stays FALSE (keep ClearType for the dense
       mono telemetry — only BootWindow needs True, for its opacity fade). -->
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6" CornerRadius="0"
                        GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- SigilGeo (the boot hexagram) is shared from Palette.xaml; used here as the caption brand mark -->
    <Style x:Key="CaptionBtn" TargetType="Button">
      <Setter Property="Width" Value="46"/><Setter Property="Height" Value="36"/>
      <Setter Property="Foreground" Value="{StaticResource DimBrush}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="10"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#14E6EEF6"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.7"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CaptionCloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#2EFF6B6B"/>
                <Setter Property="Foreground" Value="{StaticResource DangerBrightBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.7"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="36"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="216"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ===== CAPTION (Row 0) — split at the 216 column so rail + content each read as ONE surface ===== -->
    <!-- left zone = SurfaceBrush, continuous with the rail; the brand lives here (draggable) -->
    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
      <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
        <!-- Brand sigil = an arc-reactor. When the panel is loading / running an action (Busy), a cyan
             "working" ring spins up around it and the gold sigil counter-rotates faintly. Cyan is the live
             accent; the gold stays etched (never glows). At rest both are still. -->
        <Grid Width="22" Height="22" VerticalAlignment="Center">
          <Ellipse Width="22" Height="22" Stroke="{StaticResource TealBrush}" StrokeThickness="1"
                   StrokeDashArray="2.2 3.6" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform><RotateTransform/></Ellipse.RenderTransform>
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Style.Triggers>
                  <!-- Busy: fade the working-ring in (and out). One-shot opacity — safe under reduce-motion. -->
                  <DataTrigger Binding="{Binding Busy}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.9" Duration="0:0:0.3"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                  <!-- The continuous rotation only spins when the OS allows animations (reduce-motion -> static ring). -->
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Busy}" Value="True"/>
                      <Condition Binding="{Binding Source={x:Static SystemParameters.ClientAreaAnimation}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                      <BeginStoryboard Name="BusySpin">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                           From="0" To="360" Duration="0:0:2.2" RepeatBehavior="Forever"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="BusySpin"/>
                    </MultiDataTrigger.ExitActions>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <Path Data="{StaticResource SigilGeo}" Stretch="Uniform" Width="16" Height="16"
                HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1" Opacity="0.85">
            <Path.RenderTransform><RotateTransform/></Path.RenderTransform>
            <Path.Style>
              <Style TargetType="Path">
                <Style.Triggers>
                  <!-- faint counter-rotation while Busy; only when the OS allows animations (reduce-motion -> still) -->
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Busy}" Value="True"/>
                      <Condition Binding="{Binding Source={x:Static SystemParameters.ClientAreaAnimation}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                      <BeginStoryboard Name="SigilTurn">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                           From="0" To="-360" Duration="0:0:7" RepeatBehavior="Forever"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="SigilTurn"/>
                    </MultiDataTrigger.ExitActions>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </Path.Style>
          </Path>
        </Grid>
        <TextBlock Text="D O K I D E X" Margin="9,0,0,0" VerticalAlignment="Center"
                   FontFamily="Segoe UI Variable Display, Segoe UI Light, Segoe UI"
                   FontWeight="Thin" FontSize="12.5" Foreground="{StaticResource TextBrush}" Opacity="0.92"/>
      </StackPanel>
    </Border>
    <!-- right zone = BgBrush, continuous with the content; drag region + window controls -->
    <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button x:Name="MinBtn"   Style="{StaticResource CaptionBtn}"      Content="&#xE921;" Click="OnMinimize"  ToolTip="Minimize"/>
          <Button x:Name="MaxBtn"   Style="{StaticResource CaptionBtn}"      Content="&#xE922;" Click="OnMaxRestore" ToolTip="Maximize"/>
          <Button x:Name="CloseBtn" Style="{StaticResource CaptionCloseBtn}" Content="&#xE8BB;" Click="OnClose"      ToolTip="Close"/>
        </StackPanel>
        <Grid/>
      </DockPanel>
    </Border>

    <!-- ===== LEFT RAIL (Row 1) — wordmark moved to the caption; GPU meter is first ===== -->
    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,1,0">
      <DockPanel Margin="14,16,14,12">

        <!-- GPU meter -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
          <TextBlock Text="{Binding Gpu.GroupLabel}" Foreground="{StaticResource DimBrush}" FontSize="10.5" Margin="0,0,0,5" TextTrimming="CharacterEllipsis"/>
          <TextBlock Text="{Binding Gpu.Headline}" Style="{StaticResource Mono}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
          <Border Height="4" Background="{StaticResource BgBrush}" CornerRadius="2">
            <ProgressBar Minimum="0" Maximum="{Binding Gpu.TotalMB}" Value="{Binding Gpu.UsedMB}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{Binding Gpu.ActiveGroup, Converter={StaticResource GroupAccent}}"/>
          </Border>
          <TextBlock Text="{Binding Gpu.SubLine}" Foreground="{Binding Gpu.Warn, Converter={StaticResource WarnBrush}}"
                     Style="{StaticResource Mono}" FontSize="11" Margin="0,5,0,0"/>
          <TextBlock Text="local intelligence stack" Foreground="{StaticResource DimBrush}" FontSize="10.5" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- nav -->
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="VIEW" Style="{StaticResource SectionHeader}"/>
          <Button x:Name="NavDashBtn" Content="Dashboard" Style="{StaticResource NavBtn}" Tag="active" Click="NavDashboard"/>
          <Button x:Name="NavStudioBtn" Content="Studio" Style="{StaticResource NavBtn}" Click="NavStudio"/>
          <Button x:Name="NavLogsBtn" Content="Logs" Style="{StaticResource NavBtn}" Click="NavLogs"/>
        </StackPanel>

        <!-- global actions (bottom) -->
        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="GLOBAL" Style="{StaticResource SectionHeader}" Margin="2,0,0,6"/>
          <Button Content="⟳  Check Updates" Style="{StaticResource NavBtn}" Command="{Binding CheckUpdatesCommand}"
                  ToolTip="Check for newer SwarmUI (git) + llama-swap (GitHub) releases."/>
          <Button Content="✓  Verify stack" Style="{StaticResource NavBtn}" Command="{Binding VerifyCommand}"
                  ToolTip="Full-stack smoke test (opens a console)."/>
          <Button Content="⏻  Stop All" Style="{StaticResource NavBtn}"
                  Command="{Binding StopAllCommand}" ToolTip="Stop every service and free the GPU."/>   <!-- DimBrush idle: red is reserved for crashed-state alarm, not a standing rail action -->


          <!-- panel version + its own auto-updater -->
          <Border Margin="0,12,0,0" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="2,8,0,0">
            <StackPanel>
              <TextBlock Style="{StaticResource Mono}" Foreground="{StaticResource DimBrush}" FontSize="10.5">
                <Run Text="panel "/><Run Text="{Binding AppVersion}"/>
              </TextBlock>
              <Button Content="◆  Update &amp; restart" Style="{StaticResource NavBtn}" Margin="0,4,0,0" FontSize="12"
                      Foreground="{StaticResource TealBrush}" Command="{Binding UpdateAndRestartCommand}"
                      Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolVis}}"
                      ToolTip="{Binding UpdateText}"/>
              <TextBlock Text="{Binding UpdateText}" Style="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource TealBrush}"
                         Margin="2,3,0,0" TextWrapping="Wrap" Visibility="{Binding UpdateHasMessage, Converter={StaticResource BoolVis}}"/>
              <ProgressBar Height="3" Margin="2,4,0,0" Minimum="0" Maximum="100" Value="{Binding UpdateProgress}"
                           Background="{StaticResource BgBrush}" Foreground="{StaticResource TealBrush}" BorderThickness="0"
                           Visibility="{Binding UpdateBusy, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <Grid/>
      </DockPanel>
    </Border>

    <!-- ===== CONTENT ===== -->
    <ContentControl Grid.Row="1" Grid.Column="1" x:Name="PageHost"/>

    <!-- ===== STATUS STRIP (Row 2) — leading live pip bound Gpu.ActiveGroup (grey/cyan/gold) ===== -->
    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0">
      <DockPanel Margin="14,6">
        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource DimBrush}" FontSize="11" VerticalAlignment="Center">
          <Run Text="updated "/><Run Text="{Binding LastUpdated}"/>
        </TextBlock>
        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,8,0"
                 Fill="{Binding Gpu.ActiveGroup, Converter={StaticResource GroupAccent}}"/>
        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}" Opacity="0.85" FontSize="12"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
