<Window x:Class="DokiDex.Control.Views.InstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DokiDex — Setup" Width="720" Height="800"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        WindowStyle="None" Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">

  <!-- Custom chrome matching MainWindow: WindowStyle=None + WindowChrome gives a draggable caption +
       our own window buttons instead of the grey OS title bar, so the installer reads as one piece with
       the app. AllowsTransparency stays FALSE (keep ClearType for the dense mono log). -->
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="0" CornerRadius="0"
                        GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- caption buttons (shared shape with MainWindow's chrome) -->
    <Style x:Key="CaptionBtn" TargetType="Button">
      <Setter Property="Width" Value="46"/><Setter Property="Height" Value="38"/>
      <Setter Property="Foreground" Value="{StaticResource DimBrush}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="10"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#14E6EEF6"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.7"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CaptionCloseBtn" TargetType="Button" BasedOn="{StaticResource CaptionBtn}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#2EFF6B6B"/>
                <Setter Property="Foreground" Value="{StaticResource DangerBrightBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.7"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <!-- A single hairline frame around the whole window (no OS chrome to draw one for us). -->
  <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Background="{StaticResource BgBrush}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="38"/>    <!-- caption -->
        <RowDefinition Height="Auto"/>  <!-- hero -->
        <RowDefinition Height="*"/>     <!-- body (config OR progress) -->
        <RowDefinition Height="Auto"/>  <!-- footer -->
      </Grid.RowDefinitions>

      <!-- ===== caption (draggable) — brand mark + window controls ===== -->
      <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <Button Style="{StaticResource CaptionBtn}"      Content="&#xE921;" Click="OnMinimize" ToolTip="Minimize"/>
            <Button Style="{StaticResource CaptionCloseBtn}" Content="&#xE8BB;" Click="OnClose"    ToolTip="Close"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
            <Path Data="{StaticResource SigilGeo}" Stretch="Uniform" Width="15" Height="15" VerticalAlignment="Center"
                  Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1" Opacity="0.85"/>
            <TextBlock Text="D O K I D E X" Margin="10,0,0,0" VerticalAlignment="Center"
                       FontFamily="Segoe UI Variable Display, Segoe UI Light, Segoe UI"
                       FontWeight="Thin" FontSize="12" Foreground="{StaticResource TextBrush}" Opacity="0.9"/>
            <TextBlock Text="//  SETUP" Margin="10,0,0,0" VerticalAlignment="Center"
                       Style="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource DimBrush}"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ===== hero ===== -->
      <StackPanel Grid.Row="1" Margin="28,22,28,4">
        <TextBlock Text="DokiDex" Style="{StaticResource H1}" Foreground="{StaticResource ReactorGoldBrush}"/>
        <TextBlock Text="install + manage the fully-local AI stack" Style="{StaticResource Mono}"
                   Foreground="{StaticResource DimBrush}" FontSize="12" Margin="0,2,0,0"/>
      </StackPanel>

      <!-- ===== body ===== -->
      <Grid Grid.Row="2">
        <!-- config (idle) — scrolls -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,8,28,8"
                      Visibility="{Binding Idle, Converter={StaticResource BoolVis}}">
          <StackPanel>
            <TextBlock Text="MODE" Style="{StaticResource SectionHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
              <RadioButton Content="Fresh install" GroupName="m" Foreground="{StaticResource TextBrush}" Margin="0,0,20,0"
                           IsChecked="{Binding IsFresh, Mode=OneWay}" Command="{Binding ChooseFreshCommand}"/>
              <RadioButton Content="Use an existing DokiDex folder" GroupName="m" Foreground="{StaticResource TextBrush}"
                           IsChecked="{Binding IsAdopt, Mode=OneWay}" Command="{Binding ChooseAdoptCommand}"/>
            </StackPanel>

            <TextBlock Text="LOCATION" Style="{StaticResource SectionHeader}"/>
            <DockPanel Margin="0,6,0,4">
              <Button DockPanel.Dock="Right" Content="Choose…" Style="{StaticResource IconBtn}" Margin="8,0,0,0" Command="{Binding PickFolderCommand}"/>
              <TextBox Text="{Binding Home, UpdateSourceTrigger=PropertyChanged}" Foreground="{StaticResource TextBrush}"
                       Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource BorderBrush2}"
                       BorderThickness="1" Padding="9,7" VerticalContentAlignment="Center"/>
            </DockPanel>
            <TextBlock Text="{Binding EstimateText}" Style="{StaticResource Mono}" Foreground="{StaticResource DimBrush}"
                       FontSize="11" Margin="0,0,0,16"/>

            <!-- components (fresh only) -->
            <StackPanel Visibility="{Binding IsFresh, Converter={StaticResource BoolVis}}">
              <TextBlock Text="COMPONENTS" Style="{StaticResource SectionHeader}"/>
              <StackPanel Margin="0,6,0,16">
                <CheckBox Content="Coder LLM models (~80 GB) — chat + code" Foreground="{StaticResource TextBrush}" IsChecked="{Binding CoderModels}" Margin="0,3"/>
                <CheckBox Content="Media — image / video / audio (SwarmUI)" Foreground="{StaticResource TextBrush}" IsChecked="{Binding Media}" Margin="0,3"/>
                <CheckBox Content="Full media quality kit (~100 GB; else a lean set)" Foreground="{StaticResource TextBrush}" IsChecked="{Binding ModelsFull}" IsEnabled="{Binding Media}" Margin="22,3,0,3"/>
                <CheckBox Content="Speech — TTS (voice out)" Foreground="{StaticResource TextBrush}" IsChecked="{Binding Tts}" Margin="0,3"/>
                <CheckBox Content="Speech — STT (voice in)" Foreground="{StaticResource TextBrush}" IsChecked="{Binding Stt}" Margin="0,3"/>
              </StackPanel>
            </StackPanel>

            <DockPanel Margin="0,0,0,4">
              <TextBlock Text="PREREQUISITES" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left"/>
              <Button Content="↻ re-check" Style="{StaticResource IconBtn}" HorizontalAlignment="Right" Command="{Binding RecheckPrereqsCommand}"/>
            </DockPanel>
            <ItemsControl ItemsSource="{Binding PrereqRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource Surface2Brush}" CornerRadius="6" Padding="10,7" Margin="0,3">
                    <DockPanel>
                      <Grid DockPanel.Dock="Left" Width="22" VerticalAlignment="Center">
                        <TextBlock Text="✓" FontSize="13" Foreground="{StaticResource TealBrush}" Visibility="{Binding Present, Converter={StaticResource BoolVis}}"/>
                        <TextBlock Text="●" FontSize="11" Foreground="{StaticResource AmberBrush}" Visibility="{Binding Present, Converter={StaticResource InvBoolVis}}"/>
                      </Grid>
                      <Button DockPanel.Dock="Right" Content="{Binding ActionLabel}" Style="{StaticResource IconBtn}" VerticalAlignment="Center"
                              Visibility="{Binding Actionable, Converter={StaticResource BoolVis}}"
                              Command="{Binding DataContext.InstallPrereqCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"/>
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="12.5"/>
                        <TextBlock Text="{Binding Note}" Foreground="{StaticResource DimBrush}" Style="{StaticResource Mono}" FontSize="10.5"/>
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>

        <!-- progress (install running / done) — the log pane fills the body, no dead space -->
        <Grid Margin="28,8,28,8" Visibility="{Binding ShowProgress, Converter={StaticResource BoolVis}}">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="INSTALL LOG" Style="{StaticResource SectionHeader}"/>
          <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" Margin="0,8" Background="Transparent" Foreground="{StaticResource TealBrush}"
                       BorderThickness="0" Visibility="{Binding Installing, Converter={StaticResource BoolVis}}"/>
          <Border Grid.Row="2" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="4">
            <TextBox x:Name="LogBox" Text="{Binding Log, Mode=OneWay}" IsReadOnly="True"
                     Background="Transparent" Foreground="{StaticResource DimBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                     BorderThickness="0" Padding="10,8"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
          </Border>
        </Grid>
      </Grid>

      <!-- ===== footer ===== -->
      <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0" Padding="28,12">
        <DockPanel>
          <TextBlock Text="{Binding StatusLine}" Foreground="{StaticResource AmberBrush}" Style="{StaticResource Mono}"
                     FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
            <StackPanel Orientation="Horizontal" Visibility="{Binding Idle, Converter={StaticResource BoolVis}}">
              <Button Content="Cancel" Style="{StaticResource BtnGhost}" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
              <Button Content="Use this folder" Style="{StaticResource BtnPrimary}" Command="{Binding AdoptCommand}"
                      Visibility="{Binding IsAdopt, Converter={StaticResource BoolVis}}"/>
              <Button Content="Install" Style="{StaticResource BtnPrimary}" Command="{Binding InstallCommand}"
                      Visibility="{Binding IsFresh, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
            <Button Content="🚀 Launch DokiDex" Style="{StaticResource BtnPrimary}" Command="{Binding LaunchCommand}"
                    Visibility="{Binding Done, Converter={StaticResource BoolVis}}"/>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
