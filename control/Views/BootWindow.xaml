<Window x:Class="DokiCode.Control.Views.BootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="BootWin"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        ShowInTaskbar="False" Topmost="True" WindowStartupLocation="CenterScreen"
        Width="900" Height="560" Background="{StaticResource VoidBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True"
        Loaded="OnLoaded" PreviewKeyDown="OnKeySkip" MouseDown="OnMouseSkip" Focusable="True">

  <!-- ===== THE SEAL IGNITES: magitek sigil = arc-reactor faceplate = powers an LCARS rail
             fed by REAL `doki status json`. One accent (cyan) emits; gold is etched metal. =====
       NB: AllowsTransparency=True is intentional and load-bearing — WPF ignores Window.Opacity
       unless it is True, and HandOff() fades Window.Opacity for the cross-dissolve into MainWindow.
       The trade is ClearType off (grayscale-AA text) for the ~3s splash; do NOT "optimize" it back
       to False or the handoff fade silently dies. -->
  <Window.Resources>
    <!-- continuous ring rotation (begun in code on Loaded; Forever; RenderTransform-only = ~free) -->
    <Storyboard x:Key="RotOuterSb" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="RotOuter" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:16"/>
    </Storyboard>
    <Storyboard x:Key="RotInnerSb" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="RotInner" Storyboard.TargetProperty="Angle" From="0" To="-360" Duration="0:0:22"/>
    </Storyboard>

    <!-- the MASTER intro timeline (begun from code: sb.Begin(this)). Every beat is ms-stamped. -->
    <Storyboard x:Key="IntroSb">
      <!-- 120: SIGIL DRAW-ON — gold engraving traces itself (StrokeDashOffset), like a summon seal -->
      <DoubleAnimation Storyboard.TargetName="SigilStar" Storyboard.TargetProperty="StrokeDashOffset"
                       BeginTime="0:0:0.12" From="1200" To="0" Duration="0:0:0.70">
        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="SigilStar" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.12" To="0.85" Duration="0:0:0.40"/>

      <!-- 520: RINGS COME ALIVE + wordmark breathes in -->
      <DoubleAnimation Storyboard.TargetName="RingOuter" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.52" To="1" Duration="0:0:0.40"/>
      <DoubleAnimation Storyboard.TargetName="RingInner" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.52" To="1" Duration="0:0:0.40"/>
      <DoubleAnimation Storyboard.TargetName="Wordmark" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.52" To="1" Duration="0:0:0.45"/>

      <!-- 820: IGNITION (the key frame) — iris blooms with overshoot; the ONE animated blur -->
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IrisScale" Storyboard.TargetProperty="ScaleX" BeginTime="0:0:0.82">
        <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1.06" KeySpline="0.2,0.8,0.2,1"/>
        <SplineDoubleKeyFrame KeyTime="0:0:0.46" Value="1.0"  KeySpline="0.4,0,0.2,1"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IrisScale" Storyboard.TargetProperty="ScaleY" BeginTime="0:0:0.82">
        <SplineDoubleKeyFrame KeyTime="0:0:0.34" Value="1.06" KeySpline="0.2,0.8,0.2,1"/>
        <SplineDoubleKeyFrame KeyTime="0:0:0.46" Value="1.0"  KeySpline="0.4,0,0.2,1"/>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Iris" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" BeginTime="0:0:0.82">
        <LinearDoubleKeyFrame KeyTime="0:0:0.42" Value="34"/>
        <LinearDoubleKeyFrame KeyTime="0:0:0.66" Value="20"/>
      </DoubleAnimationUsingKeyFrames>
      <!-- CHANNEL-FLOOD: cyan light runs OUT along the gold engraving, then settles (magitek) -->
      <DoubleAnimation Storyboard.TargetName="SigilFlood" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.88" To="0.9" Duration="0:0:0.12"/>
      <DoubleAnimation Storyboard.TargetName="SigilFlood" Storyboard.TargetProperty="Opacity" BeginTime="0:0:1.18" To="0.32" Duration="0:0:0.40"/>

      <!-- 900: skip hint + the ONE corner reticle + the one baseline rule -->
      <DoubleAnimation Storyboard.TargetName="SkipHint" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.90" To="0.4" Duration="0:0:0.40"/>
      <DoubleAnimation Storyboard.TargetName="Reticle" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.90" To="1" Duration="0:0:0.30"/>
      <DoubleAnimation Storyboard.TargetName="BaselineScale" Storyboard.TargetProperty="ScaleX" BeginTime="0:0:0.90" To="1" Duration="0:0:0.45"/>

      <!-- 1080: TIE-LINE FIRES — a cyan packet travels core -> rail; the spine then lights top->bottom -->
      <DoubleAnimation Storyboard.TargetName="Packet" Storyboard.TargetProperty="Opacity" BeginTime="0:0:1.08" To="1" Duration="0:0:0.05"/>
      <DoubleAnimation Storyboard.TargetName="PacketX" Storyboard.TargetProperty="X" BeginTime="0:0:1.08" From="0" To="196" Duration="0:0:0.24"/>
      <DoubleAnimation Storyboard.TargetName="Packet" Storyboard.TargetProperty="Opacity" BeginTime="0:0:1.32" To="0" Duration="0:0:0.10"/>
      <DoubleAnimation Storyboard.TargetName="SpineScale" Storyboard.TargetProperty="ScaleY" BeginTime="0:0:1.32" To="1" Duration="0:0:0.20"/>

      <!-- 1320: GPU headline block resolves (real data snaps into the bound text) -->
      <DoubleAnimation Storyboard.TargetName="GpuBlock" Storyboard.TargetProperty="Opacity" BeginTime="0:0:1.34" To="1" Duration="0:0:0.16"/>
      <DoubleAnimation Storyboard.TargetName="GpuBlockX" Storyboard.TargetProperty="X" BeginTime="0:0:1.34" From="10" To="0" Duration="0:0:0.18"/>

      <!-- 2080: coder model line -->
      <DoubleAnimation Storyboard.TargetName="CoderLine" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2.08" To="1" Duration="0:0:0.18"/>

      <!-- 2600: RESOLVE word + the reactor EXHALE (one bloom) -->
      <DoubleAnimation Storyboard.TargetName="Resolve" Storyboard.TargetProperty="Opacity" BeginTime="0:0:2.60" To="1" Duration="0:0:0.22"/>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Iris" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" BeginTime="0:0:2.60">
        <LinearDoubleKeyFrame KeyTime="0:0:0.14" Value="38"/>
        <LinearDoubleKeyFrame KeyTime="0:0:0.30" Value="22"/>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>
  </Window.Resources>

  <Grid x:Name="Root">
    <Grid.Background>
      <!-- soft vignette: a hair warmer at the left-third crest, pulling the eye; pure void elsewhere -->
      <RadialGradientBrush GradientOrigin="0.30,0.5" Center="0.30,0.5" RadiusX="0.95" RadiusY="0.95">
        <GradientStop Color="#FF0B0F16" Offset="0.0"/>
        <GradientStop Color="#FF05070B" Offset="0.75"/>
      </RadialGradientBrush>
    </Grid.Background>

    <!-- ===== THE CREST (left third): sigil + reactor are ONE object ===== -->
    <Canvas x:Name="Crest" Width="300" Height="300" HorizontalAlignment="Left" VerticalAlignment="Center"
            Margin="110,0,0,0" RenderTransformOrigin="0.5,0.5">
      <Canvas.RenderTransform><ScaleTransform x:Name="CrestScale" ScaleX="1" ScaleY="1"/></Canvas.RenderTransform>

      <!-- (A) magitek sigil — gold hairline hexagram, NO fill, draws itself via StrokeDashOffset -->
      <Path x:Name="SigilStar" Stroke="{StaticResource ReactorGoldBrush}" StrokeThickness="1"
            StrokeDashArray="1200" StrokeDashOffset="1200" Opacity="0"
            Data="M150,18 L264,84 L264,216 L150,282 L36,216 L36,84 Z
                  M150,40 L242,200 L58,200 Z   M150,260 L58,100 L242,100 Z"/>

      <!-- (B) reactor arc-rings — rotate forever (begun in code), fade in at 520 -->
      <Ellipse x:Name="RingOuter" Canvas.Left="55" Canvas.Top="55" Width="190" Height="190" Opacity="0"
               Stroke="{StaticResource ReactorDimBrush}" StrokeThickness="1.5" StrokeDashArray="34 10" RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform><RotateTransform x:Name="RotOuter"/></Ellipse.RenderTransform>
      </Ellipse>
      <Ellipse x:Name="RingInner" Canvas.Left="80" Canvas.Top="80" Width="140" Height="140" Opacity="0"
               Stroke="{StaticResource ReactorDimBrush}" StrokeThickness="1" StrokeDashArray="6 8" RenderTransformOrigin="0.5,0.5">
        <Ellipse.RenderTransform><RotateTransform x:Name="RotInner"/></Ellipse.RenderTransform>
      </Ellipse>

      <!-- (D) channel-flood: cyan copy of the sigil; light runs out along the gold channels at ignition -->
      <Path x:Name="SigilFlood" Stroke="{StaticResource ReactorBrush}" StrokeThickness="1.2" Opacity="0"
            Data="M150,18 L264,84 L264,216 L150,282 L36,216 L36,84 Z
                  M150,40 L242,200 L58,200 Z   M150,260 L58,100 L242,100 Z">
        <Path.Effect><DropShadowEffect Color="#FF35E0F0" BlurRadius="6" ShadowDepth="0"/></Path.Effect>
      </Path>

      <!-- (C) igniting iris — the ONLY animated DropShadow; the single brightest point -->
      <Ellipse x:Name="Iris" Canvas.Left="125" Canvas.Top="125" Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#FFCFF6FF" Offset="0.0"/>
            <GradientStop Color="#FF35E0F0" Offset="0.55"/>
            <GradientStop Color="#FF1FB8CC" Offset="1.0"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
        <Ellipse.RenderTransform><ScaleTransform x:Name="IrisScale" ScaleX="0" ScaleY="0"/></Ellipse.RenderTransform>
        <Ellipse.Effect><DropShadowEffect Color="#FF35E0F0" BlurRadius="0" ShadowDepth="0" Opacity="0.9"/></Ellipse.Effect>
      </Ellipse>
    </Canvas>

    <!-- ===== TIE-LINE: the literal wire core -> rail; one cyan packet travels it ===== -->
    <Canvas>
      <Line X1="364" Y1="280" X2="560" Y2="280" Stroke="{StaticResource ReactorDimBrush}" StrokeThickness="1" Opacity="0.45"/>
      <Rectangle x:Name="Packet" Canvas.Left="364" Canvas.Top="279" Width="24" Height="2" Opacity="0">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0035E0F0" Offset="0"/><GradientStop Color="#FF35E0F0" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
        <Rectangle.RenderTransform><TranslateTransform x:Name="PacketX"/></Rectangle.RenderTransform>
      </Rectangle>
    </Canvas>

    <!-- ===== LCARS RAIL — one cyan spine + rows from REAL doki status json ===== -->
    <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="560,0,0,0" Width="290">
      <Rectangle x:Name="Spine" Width="3" Height="252" HorizontalAlignment="Left" VerticalAlignment="Center"
                 Fill="{StaticResource ReactorBrush}" RenderTransformOrigin="0.5,0" Opacity="0.9">
        <Rectangle.RenderTransform><ScaleTransform x:Name="SpineScale" ScaleY="0"/></Rectangle.RenderTransform>
      </Rectangle>
      <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="PRE-FLIGHT  //  doki status json" FontSize="10" Foreground="{StaticResource DimBrush}"
                   FontFamily="Cascadia Mono, Consolas" Margin="0,0,0,12"/>

        <!-- GPU headline block (real telemetry snaps into the bound text) -->
        <StackPanel x:Name="GpuBlock" Opacity="0" Margin="0,0,0,14">
          <StackPanel.RenderTransform><TranslateTransform x:Name="GpuBlockX"/></StackPanel.RenderTransform>
          <TextBlock Text="{Binding GpuGroupLabel}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="{StaticResource DimBrush}"/>
          <TextBlock Text="{Binding GpuMetrics}" FontFamily="Cascadia Mono, Consolas" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource BootTextBrush}" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- service rows -->
        <ItemsControl ItemsSource="{Binding Rows}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid x:Name="RowRoot" Opacity="0" Margin="0,0,0,9">
                <Grid.RenderTransform><TranslateTransform x:Name="RowX" X="12"/></Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Tick}" Foreground="{Binding TickBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{StaticResource BootTextBrush}" Opacity="0.82" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{Binding ValueBrush}" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
              </Grid>
              <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Shown}" Value="True">
                  <DataTrigger.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RowRoot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                        <DoubleAnimation Storyboard.TargetName="RowX" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.14"/>
                      </Storyboard>
                    </BeginStoryboard>
                  </DataTrigger.EnterActions>
                </DataTrigger>
              </DataTemplate.Triggers>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock x:Name="CoderLine" Text="{Binding CoderModelLine}" Opacity="0" FontFamily="Cascadia Mono, Consolas"
                   FontSize="11" Foreground="{StaticResource DimBrush}" Margin="16,5,0,16" TextTrimming="CharacterEllipsis"/>

        <!-- the seal closes: gold resolve word -->
        <TextBlock x:Name="Resolve" Text="{Binding ResolveText}" Opacity="0" FontSize="14" Margin="16,0,0,0"
                   FontFamily="Segoe UI Variable Display, Segoe UI Light, Segoe UI" Foreground="{StaticResource ReactorGoldBrush}"/>
      </StackPanel>
    </Grid>

    <!-- ===== WORDMARK (top-left): per-glyph hair-spaced, Light face — never FontStretch/ScaleX ===== -->
    <TextBlock x:Name="Wordmark" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="48,40,0,0" Opacity="0"
               FontFamily="Segoe UI Variable Display, Segoe UI Light, Segoe UI">
      <Run Text="D O K I C O D E" FontSize="21" FontWeight="Thin" Foreground="{StaticResource BootTextBrush}"/><LineBreak/>
      <Run Text="local intelligence stack" FontSize="10.5" Foreground="{StaticResource DimBrush}"/>
    </TextBlock>

    <TextBlock x:Name="SkipHint" Text="— press esc to skip —" HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Margin="48,0,0,34" Opacity="0" FontSize="10.5" Foreground="{StaticResource DimBrush}"
               FontFamily="Cascadia Mono, Consolas"/>

    <!-- ONE corner reticle (top-left) + ONE baseline rule. Not four brackets (that's the cliche). -->
    <Path x:Name="Reticle" Data="M0,22 L0,0 L22,0" Stroke="{StaticResource HudFaintBrush}" StrokeThickness="1"
          HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,24,0,0" Opacity="0"/>
    <Rectangle Height="1" VerticalAlignment="Bottom" Margin="48,0,48,22" Fill="{StaticResource HudFaintBrush}" RenderTransformOrigin="0,0.5">
      <Rectangle.RenderTransform><ScaleTransform x:Name="BaselineScale" ScaleX="0"/></Rectangle.RenderTransform>
    </Rectangle>
  </Grid>
</Window>
